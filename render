services:
  - type: web
    name: household-app
    runtime: python
    buildCommand: pip install -r requirements.txt
    startCommand: uvicorn main:app --host 0.0.0.0 --port $PORT
    envVars:
      - key: GOOGLE_CREDENTIALS_JSON
        sync: false   # Renderのダッシュボードで手動設定
      - key: SPREADSHEET_ID
        sync: false   # Renderのダッシュボードで手動設定
      - key: SHEET_NAME
        value: Sheet1  # 必要に応じて変更
